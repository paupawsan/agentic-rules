{
  "_metadata": {
    "license": "MIT",
    "copyright": "Copyright (c) 2025-2026 Paulus Ery Wasito Adhi",
    "license_file": "LICENSE",
    "version": "1.4.0",
    "adapter_for": "cursor_2_0_multi_agent"
  },
  "cursor_2_0": {
    "version": "2.0",
    "multi_agent_support": true,
    "nightly_channel_required": true,
    "composer_mode": "agent",
    "features": {
      "orchestrator": {
        "enabled": true,
        "config_path": ".cursor/agents/orchestrator.md",
        "plan_mode_shortcut": "Shift+Tab",
        "global_context_marker": "@Codebase"
      },
      "sub_agents": {
        "enabled": true,
        "config_directory": ".cursor/agents",
        "available_agents": [
          {
            "name": "memory-agent",
            "file": "memory-agent.md",
            "framework_module": "memory-rules",
            "priority": "medium"
          },
          {
            "name": "rag-agent",
            "file": "rag-agent.md",
            "framework_module": "rag-rules",
            "priority": "high"
          },
          {
            "name": "critical-thinking-agent",
            "file": "critical-thinking-agent.md",
            "framework_module": "critical-thinking-rules",
            "priority": "high"
          },
          {
            "name": "docs-agent",
            "file": "docs-agent.md",
            "framework_module": "all-rules",
            "priority": "medium"
          },
          {
            "name": "test-agent",
            "file": "test-agent.md",
            "framework_module": "critical-thinking-rules,memory-rules",
            "priority": "medium"
          }
        ]
      },
      "parallel_execution": {
        "enabled": true,
        "method": "git_worktrees",
        "verification_command": "git worktree list",
        "merge_strategy": "apply_button_ui"
      },
      "best_of_n_strategy": {
        "enabled": true,
        "multiple_models_support": true,
        "comparison_ui": "tab_based",
        "selection_method": "user_choice"
      }
    },
    "framework_integration": {
      "bootstrap_compliance": true,
      "rule_loading": "distributed_per_rule",
      "agent_coordination": "framework_based",
      "delegation_strategy": "rule_priority_based",
      "memory_sharing": true,
      "context_optimization": true
    },
    "workflow_patterns": {
      "task_decomposition": {
        "orchestrator_planning": true,
        "sub_agent_delegation": true,
        "parallel_execution": true,
        "result_synthesis": true
      },
      "quality_assurance": {
        "critical_thinking_validation": true,
        "memory_pattern_matching": true,
        "rag_context_verification": true
      },
      "coordination": {
        "rule_interconnections": true,
        "framework_algorithms": true,
        "transparency_logging": true
      }
    }
  }
}
